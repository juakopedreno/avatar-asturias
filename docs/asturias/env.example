# Avatar Principado de Asturias — copiar a .env en la raíz del monorepo

NODE_ENV=development

API_PORT=3000
CORS_ORIGIN=http://localhost:8080

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/avatar_asturias
JWT_SECRET=REEMPLAZAR_POR_SECRETO_SEGURO
JWT_REFRESH_SECRET=REEMPLAZAR_POR_SECRETO_SEGURO_REFRESH

# Front (Vercel)
VITE_API_BASE_URL=http://localhost:3000/api

# RAG
OPENAI_API_KEY=
RAG_OPENAI_MODEL=gpt-4o-mini
STT_OPENAI_MODEL=whisper-1

# Avatar Anam (hiperrealista)
AVATAR_RUNTIME=anam
ANAM_API_KEY=
ANAM_BASE_URL=https://api.anam.ai
ANAM_PERSONA_ID=
ANAM_PERSONA_NAME=Asistente Principado de Asturias
ANAM_AVATAR_ID=
ANAM_AVATAR_MODEL=cara-3
ANAM_VOICE_ID=
ANAM_LLM_ID=
ANAM_SYSTEM_PROMPT=Eres el asistente virtual del Principado de Asturias. Pronuncia exactamente el texto que te indiquen en cada turno. Tono claro, cercano e institucional. No inventes datos ni normativa; si no tienes información, dilo con naturalidad.
ANAM_MAX_SESSION_LENGTH_SECONDS=1800
ANAM_SKIP_GREETING=false

# Wearables desactivados en esta variante (no configurar Fitbit)
