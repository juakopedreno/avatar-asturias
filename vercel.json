{
  "buildCommand": "npm run build -w @avatar/web",
  "outputDirectory": "apps/web/dist",
  "installCommand": "NPM_CONFIG_PRODUCTION=false npm ci",
  "framework": null,
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/logo-torremolinos.png?v=3" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
