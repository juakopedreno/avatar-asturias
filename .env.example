# Shared
NODE_ENV=development

# API
API_PORT=3000
PORT=
# Orígenes CORS separados por coma (producción: URL del frontend, ej. https://avatar-torremolinos.vercel.app)
CORS_ORIGIN=http://localhost:8080

# Front (Vercel): VITE_API_BASE_URL = URL base de la API terminada en /api (ej. https://xxx.up.railway.app/api).
# Si solo pones el host sin /api, el cliente añade /api automáticamente.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/avatar_torremolinos
JWT_SECRET=REEMPLAZAR_POR_SECRETO_SEGURO
JWT_REFRESH_SECRET=REEMPLAZAR_POR_SECRETO_SEGURO_REFRESH

# AI / Providers
OPENAI_API_KEY=
STT_OPENAI_MODEL=whisper-1
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
DID_API_KEY=

# Avatar runtime selector: anam | mock
AVATAR_RUNTIME=anam

# Anam
ANAM_API_KEY=
ANAM_BASE_URL=https://api.anam.ai
ANAM_PERSONA_ID=
ANAM_PERSONA_NAME=Asistente SHA Bienestar
ANAM_AVATAR_ID=30fa96d0-26c4-4e55-94a0-517025942e18
ANAM_AVATAR_MODEL=
ANAM_VOICE_ID=
ANAM_LLM_ID=
ANAM_SYSTEM_PROMPT=Eres el asistente de salud y bienestar de SHA Wellness Clinic. Pronuncia el texto que te den en cada turno; no improvises turismo ni playas. Tono cálido, breve y profesional.
ANAM_MAX_SESSION_LENGTH_SECONDS=1800
ANAM_SKIP_GREETING=false

# Fitbit (wearables) — credenciales de dev.fitbit.com / tu aplicación OAuth
# FITBIT_REDIRECT_URI debe ser IDÉNTICA a "Callback URL" en el portal Fitbit (mismo host, puerto y ruta).
# Ruta del backend Nest: /api/wearables/fitbit/callback (API_PORT por defecto 3000).
# Si en Fitbit tenías p. ej. http://127.0.0.1:8088/callback, cámbiala en el portal a la URL de abajo o
# ajusta API_PORT y esta variable en sync; de lo contrario el intercambio de code fallará.
#
# Producción: la web en Vercel/dominio público NO cambia la URL de callback de Fitbit. Si en dev.fitbit.com
# sigue registrado 127.0.0.1, tras autorizar Fitbit redirigirá al usuario a localhost (fallará en dispositivos
# reales). Registra ahí la URL HTTPS de TU API desplegada, p. ej.:
#   https://TU-API.ejemplo.com/api/wearables/fitbit/callback
# y pon la MISMA cadena en FITBIT_REDIRECT_URI del entorno de producción (Vercel/Railway/Fly, etc.).
FITBIT_CLIENT_ID=23V2G6
FITBIT_CLIENT_SECRET=ef5cf3281ad65a10b327fbae18156e31
FITBIT_REDIRECT_URI=http://127.0.0.1:3000/api/wearables/fitbit/callback

# Depuración Fitbit (opcional): GET /api/wearables/me/realtime?diagnostics=1 devuelve httpStatus y errores de las peticiones extra.
# Caché en servidor del endpoint realtime (ms); reduce llamadas a Fitbit y evita 429. Por defecto 180000 (3 min).
# WEARABLES_REALTIME_CACHE_MS=180000
