# Shared
NODE_ENV=development

# API
API_PORT=3000
PORT=
# Orígenes CORS separados por coma (producción: URL del frontend, ej. https://avatar-torremolinos.vercel.app)
CORS_ORIGIN=http://localhost:8080
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/avatar_torremolinos
JWT_SECRET=REEMPLAZAR_POR_SECRETO_SEGURO
JWT_REFRESH_SECRET=REEMPLAZAR_POR_SECRETO_SEGURO_REFRESH

# AI / Providers
OPENAI_API_KEY=
STT_OPENAI_MODEL=whisper-1
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
DID_API_KEY=

# Avatar runtime selector: anam | mock
AVATAR_RUNTIME=anam

# Anam
ANAM_API_KEY=
ANAM_BASE_URL=https://api.anam.ai
ANAM_PERSONA_ID=
ANAM_PERSONA_NAME=Asistente SHA Bienestar
ANAM_AVATAR_ID=30fa96d0-26c4-4e55-94a0-517025942e18
ANAM_AVATAR_MODEL=
ANAM_VOICE_ID=
ANAM_LLM_ID=
ANAM_SYSTEM_PROMPT=Eres el asistente de salud y bienestar de SHA Wellness Clinic. Pronuncia el texto que te den en cada turno; no improvises turismo ni playas. Tono cálido, breve y profesional.
ANAM_MAX_SESSION_LENGTH_SECONDS=1800
ANAM_SKIP_GREETING=false

# Fitbit (wearables)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REDIRECT_URI=http://127.0.0.1:3000/api/wearables/fitbit/callback
