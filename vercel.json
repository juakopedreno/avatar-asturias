{
  "installCommand": "cd \"$(git rev-parse --show-toplevel)\" && npm install",
  "buildCommand": "cd \"$(git rev-parse --show-toplevel)\" && npm run build:vercel-web",
  "outputDirectory": "apps/web/dist",
  "framework": null,
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/logo-torremolinos.png?v=3" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
