{
  "name": "avatar-torremolinos-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @avatar/web",
    "dev:api": "npm run start:dev -w @avatar/api",
    "db:deploy": "dotenv -e .env -- npm run db:deploy -w @avatar/api",
    "hardening:bootstrap": "bash ./scripts/hardening-bootstrap.sh",
    "hardening:smoke": "bash ./scripts/hardening-smoke.sh",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build -w @avatar/web",
    "build:vercel-web": "bash ./scripts/vercel-build-web.sh",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "jsdom": "^29.0.0",
    "prettier": "^3.5.3"
  }
}
