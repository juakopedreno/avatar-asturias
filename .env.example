# Shared
NODE_ENV=development

# API
API_PORT=3000
PORT=
# Orígenes CORS separados por coma (producción: URL del frontend, ej. https://avatar-torremolinos.vercel.app)
CORS_ORIGIN=http://localhost:8080
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/avatar_torremolinos
JWT_SECRET=REEMPLAZAR_POR_SECRETO_SEGURO
JWT_REFRESH_SECRET=REEMPLAZAR_POR_SECRETO_SEGURO_REFRESH

# AI / Providers
OPENAI_API_KEY=
STT_OPENAI_MODEL=whisper-1
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
DID_API_KEY=

# Avatar runtime selector: anam | mock
AVATAR_RUNTIME=anam

# Anam
ANAM_API_KEY=
ANAM_BASE_URL=https://api.anam.ai
ANAM_PERSONA_ID=
ANAM_PERSONA_NAME=Asistente Torremolinos
ANAM_AVATAR_ID=30fa96d0-26c4-4e55-94a0-517025942e18
ANAM_AVATAR_MODEL=
ANAM_VOICE_ID=
ANAM_LLM_ID=
ANAM_SYSTEM_PROMPT=Eres el asistente oficial de turismo de Torremolinos para un SaaS municipal. Responde en espanol claro, tono cercano y profesional. Prioriza informacion util para visitantes y evita inventar datos.
ANAM_MAX_SESSION_LENGTH_SECONDS=1800
ANAM_SKIP_GREETING=false
